# Production (example)
# Copy to `.env.production` and adjust if needed.

# API base URL (NO /api suffix)
VITE_API_BASE_URL=https://api.pyonea.com

# API base URL with version path
VITE_API_URL=https://api.pyonea.com/api/v1

# Site name
VITE_APP_NAME=PIU Admin Portal

# Environment label
VITE_ENV=production

# Session timeout (minutes)
VITE_SESSION_TIMEOUT=60

# reCAPTCHA v3 site key
VITE_RECAPTCHA_SITE_KEY=6LewVqssAAAAAFrjyj_dvwYZgQoFEFng_cIRHE7T

